<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aidrclaw.core.mapper.StorageFileMapper">

    <resultMap id="StorageFileResult" type="com.aidrclaw.core.entity.StorageFile">
        <id column="id" property="id"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_hash" property="fileHash"/>
        <result column="mime_type" property="mimeType"/>
        <result column="business_type" property="businessType"/>
        <result column="business_id" property="businessId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.aidrclaw.core.entity.StorageFile">
        INSERT INTO storage_file (file_path, file_size, file_hash, mime_type, business_type, business_id, created_at)
        VALUES (#{filePath}, #{fileSize}, #{fileHash}, #{mimeType}, #{businessType}, #{businessId}, #{createdAt})
    </insert>

    <select id="selectById" resultMap="StorageFileResult">
        SELECT * FROM storage_file WHERE id = #{id}
    </select>

    <select id="selectByBusinessId" resultMap="StorageFileResult">
        SELECT * FROM storage_file WHERE business_type = #{businessType} AND business_id = #{businessId}
    </select>

    <delete id="delete">
        DELETE FROM storage_file WHERE id = #{id}
    </delete>

</mapper>
